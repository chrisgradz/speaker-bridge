# Copy this file to /etc/speaker-bridge/siriusxm.env on the Ubuntu server.
# Do not commit the real env file.

SIRIUSXM_USERNAME=''
SIRIUSXM_PASSWORD=''

# Optional. Some iHeart speaker flows expect the source account identity that
# was associated with the original Bose/iHeart account.
IHEART_SOURCE_ACCOUNT=''

# Optional. Required to read diagnostic endpoints such as speaker events and
# stored cloud responses. Use a long random value.
SPEAKER_BRIDGE_DIAGNOSTIC_TOKEN=''
